  <!-- Formspreeフォーム -->

  <form
    action="https://formspree.io/f/xxxxxxxx"
    method="POST"
    class="contact-form"
  >

```
<!-- 団体名 -->
<div class="form-group">
  <label>団体名 *</label>
  <input
    type="text"
    name="organization"
    required
  >
</div>

<!-- 担当者 -->
<div class="form-group">
  <label>担当者名 *</label>
  <input
    type="text"
    name="name"
    required
  >
</div>

<!-- メールアドレス -->
<div class="form-group">
  <label>メールアドレス *</label>
  <input
    type="email"
    name="email"
    required
  >
</div>

<!-- 電話番号 -->
<div class="form-group">
  <label>電話番号</label>
  <input
    type="tel"
    name="tel"
  >
</div>

<!-- 人数 -->
<div class="form-group">
  <label>参加予定人数 *</label>
  <input
    type="number"
    name="participants"
    min="1"
    required
  >
</div>

<!-- 希望日 -->
<div class="form-group">
  <label>希望日</label>
  <input
    type="date"
    name="preferred_date"
  >
</div>

<!-- 希望内容 -->
<div class="form-group">
  <label>希望内容</label>

  <select name="request_type">

    <option>視察のみ</option>

    <option>講演のみ</option>

    <option>視察＋講演</option>

    <option>相談したい</option>

  </select>
</div>

<!-- 視察目的 -->
<div class="form-group">
  <label>視察目的・知りたい内容 *</label>

  <textarea
    name="purpose"
    required
    placeholder="視察の目的や知りたい内容をご記入ください"
  ></textarea>
</div>

<!-- 送信ボタン -->
<button
  type="submit"
  class="form-submit"
>
  視察を申し込む
</button>
```

  </form>

